---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroHome from '../components/sections/HeroHome.astro';
import FeatureCard from '../components/sections/FeatureCard.astro';
import ChannelCard from '../components/sections/ChannelCard.astro';
import Lede from '../components/ui/Lede.astro';
import Eyebrow from '../components/ui/Eyebrow.astro';
import SectionTitle from '../components/ui/SectionTitle.astro';
import Callout from '../components/ui/Callout.astro';
import ImagePlaceholder from '../components/ui/ImagePlaceholder.astro';
import CTABanner from '../components/ui/CTABanner.astro';
import OrganizationSchema from '../components/schema/OrganizationSchema.astro';

const channels = [
  {
    title: 'Independent retail',
    body: 'Flexible pack sizes, reliable weekly delivery, competitive wholesale pricing.',
    phase: '1' as const,
  },
  {
    title: 'Cash & carry and wholesale',
    body: 'Bulk formats, promotional activity, clear trading terms.',
    phase: '1' as const,
  },
  {
    title: 'Foodservice',
    body: 'Catering packs, consistency of supply, provenance-led category advice.',
    phase: '1' as const,
  },
  {
    title: 'Multiples & export',
    body: 'Approached once our own-brand programme is proven and track record established.',
    phase: '2' as const,
  },
];

const storyPlaceholders = [
  {
    category: 'Recipe',
    title: 'A basic rice recipe, done right',
    excerpt: 'How to cook perfect basmati rice, whether you are serving biryani, a North African tagine or a Sri Lankan curry.',
    href: '/food-stories/basic-rice-recipe',
    imageLabel: 'Basmati rice — recipe',
  },
  {
    category: 'Origin story',
    title: 'The journey of a peppercorn',
    excerpt: 'From the hills of Kerala to the shelves of British kitchens — how black pepper is grown, dried, graded and shipped.',
    href: '/food-stories/journey-of-a-peppercorn',
    imageLabel: 'Black pepper — origin',
  },
  {
    category: 'Cooking tip',
    title: 'Three things to know about turmeric',
    excerpt: 'Fresh vs dried, how much to use, and why heat changes its character.',
    href: '/food-stories/three-things-turmeric',
    imageLabel: 'Turmeric — cooking tip',
  },
];
---

<BaseLayout
  title="Kingsway International | UK Ethnic Food Trading & Distribution"
  description="Kingsway International is a UK-based trading and distribution partner for authentic spices, rice, pulses, lentils and ethnic grocery — for retail, wholesale and foodservice."
>
  <OrganizationSchema slot="head" />

  <HeroHome />

  <!-- Opening statement -->
  <section class="section section--white section--narrow" aria-label="Opening statement">
    <div class="container container--narrow">
      <Lede>
        Kingsway International is a United Kingdom-based trading and distribution
        company serving the authentic ethnic food needs of British retail,
        wholesale and foodservice buyers. We source directly from origin, operate
        quality as a framework rather than a slogan, and treat every case we hand
        to a customer as a promise made in our name.
      </Lede>
    </div>
  </section>

  <!-- Three-up feature strip -->
  <section class="section section--tint" aria-labelledby="features-heading">
    <div class="container">
      <div class="section-head">
        <Eyebrow>What sets Kingsway apart</Eyebrow>
        <SectionTitle id="features-heading">Three threads that run through everything we do</SectionTitle>
      </div>

      <div class="grid grid--3">
        <FeatureCard
          number="01"
          eyebrow="Our journey"
          title="Why we started Kingsway International"
          body="Why we started Kingsway International — and the convictions the company was built on."
          linkLabel="Read our story"
          linkHref="/about"
          imageLabel="Our journey"
        />
        <FeatureCard
          number="02"
          eyebrow="From source to shelf"
          title="Quality as a framework, not a slogan"
          body="Our five-stage quality framework — observable, auditable, lived."
          linkLabel="Explore the quality charter"
          linkHref="/quality"
          imageLabel="From source to shelf"
        />
        <FeatureCard
          number="03"
          eyebrow="What we trade"
          title="A focused launch portfolio"
          body="A focused launch portfolio across spices, rice, pulses and ethnic grocery."
          linkLabel="See our portfolio"
          linkHref="/products"
          imageLabel="What we trade"
        />
      </div>
    </div>
  </section>

  <!-- Quality promise callout (dark) -->
  <section class="section section--dark" aria-labelledby="quality-promise-heading">
    <div class="container">
      <div class="section-head section-head--light">
        <Eyebrow>Our quality promise</Eyebrow>
        <h2 id="quality-promise-heading" class="section-title-light">A commitment, not a slogan.</h2>
      </div>

      <Callout variant="dark" quoteMark>
        <p>
          If a product does not match the quality we have promised, we will
          replace it, refund it, or make it right &mdash; without debate.
        </p>
        <p>
          That is a commitment, not a slogan. Our five-stage quality framework
          is how we keep it.
        </p>
        <span slot="attribution">
          <a href="/quality" class="callout-link">How the framework works &rarr;</a>
        </span>
      </Callout>
    </div>
  </section>

  <!-- Four channel cards -->
  <section class="section section--white" aria-labelledby="channels-heading">
    <div class="container">
      <div class="section-head">
        <Eyebrow>Who we serve</Eyebrow>
        <SectionTitle id="channels-heading">Built for every corner of the British trade</SectionTitle>
        <p class="section-lede">
          Each channel has its own rhythm, price expectation and service requirement.
          Each is served by a dedicated commercial approach.
        </p>
      </div>

      <div class="grid grid--4">
        <ChannelCard title={channels[0].title} body={channels[0].body} phase={channels[0].phase}>
          <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 9l1-5h16l1 5" />
            <path d="M4 9v11h16V9" />
            <path d="M9 20v-6h6v6" />
          </svg>
        </ChannelCard>
        <ChannelCard title={channels[1].title} body={channels[1].body} phase={channels[1].phase}>
          <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 7l9-4 9 4v12H3z" />
            <path d="M3 11h18" />
            <path d="M3 15h18" />
          </svg>
        </ChannelCard>
        <ChannelCard title={channels[2].title} body={channels[2].body} phase={channels[2].phase}>
          <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M7 3v8a2 2 0 002 2v8" />
            <path d="M11 3v10" />
            <path d="M17 3c-1 2-2 4-2 7 0 2 1 3 2 3v8" />
          </svg>
        </ChannelCard>
        <ChannelCard title={channels[3].title} body={channels[3].body} phase={channels[3].phase}>
          <svg slot="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 21V6l6-3 6 3v15" />
            <path d="M16 21V10l4 2v9" />
            <path d="M8 10h1M8 13h1M8 16h1M12 10h1M12 13h1M12 16h1" />
          </svg>
        </ChannelCard>
      </div>

      <p class="section-foot">
        <a href="/who-we-serve" class="text-link">Who we serve &rarr;</a>
      </p>
    </div>
  </section>

  <!-- Latest from Food Stories (placeholder; hydrated in Task 5) -->
  <section class="section section--tint" aria-labelledby="stories-heading">
    <div class="container">
      <div class="section-head">
        <Eyebrow>Latest from Food Stories</Eyebrow>
        <SectionTitle id="stories-heading">Recipes, origin stories and cooking tips</SectionTitle>
        <p class="section-lede">
          The food behind the ingredients &mdash; stories from the kitchens we trade for.
        </p>
      </div>

      <div class="grid grid--3">
        {storyPlaceholders.map(story => (
          <article class="story-card">
            <ImagePlaceholder label={story.imageLabel} aspect="4/3" />
            <div class="story-card-body">
              <p class="story-card-eyebrow">{story.category}</p>
              <h3 class="story-card-title">
                <a href={story.href}>{story.title}</a>
              </h3>
              <p class="story-card-excerpt">{story.excerpt}</p>
            </div>
          </article>
        ))}
      </div>

      <p class="section-foot">
        <a href="/food-stories" class="text-link">Visit Food Stories &rarr;</a>
      </p>
    </div>
  </section>

  <!-- Trade enquiry CTA banner -->
  <CTABanner
    heading="Start a trade conversation"
    caption="We answer every enquiry within one business day."
    buttonLabel="Send an enquiry"
    buttonHref="/contact"
  />
</BaseLayout>

<style>
  /* ── Section primitives ── */
  .section {
    padding: 5rem 0;
  }

  .section--white {
    background-color: #ffffff;
  }

  .section--tint {
    background-color: var(--light-tint);
  }

  .section--dark {
    background-color: var(--primary-dark);
    color: #ffffff;
  }

  .section--narrow {
    padding: 4rem 0 3rem;
  }

  .container {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .container--narrow {
    max-width: 880px;
  }

  /* ── Section heading block ── */
  .section-head {
    max-width: 880px;
    margin-bottom: 3rem;
  }

  .section-head--light :global(.eyebrow) {
    color: var(--accent-light);
  }

  .section-title-light {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(32px, 3.6vw, 44px);
    line-height: 1.15;
    letter-spacing: -0.01em;
    color: var(--cream);
    margin: 0 0 1.5rem;
  }

  .section-lede {
    font-family: var(--font-sans);
    font-size: 17px;
    line-height: 1.65;
    color: var(--ink-soft);
    margin: 1.25rem 0 0;
    max-width: 720px;
  }

  .section-foot {
    margin-top: 3rem;
    text-align: center;
  }

  .text-link {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 600;
    color: var(--primary);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 2px;
  }

  .text-link:hover {
    color: var(--primary-dark);
  }

  /* ── Grids ── */
  .grid {
    display: grid;
    gap: 2.5rem;
  }

  .grid--3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .grid--4 {
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1.75rem;
  }

  @media (max-width: 960px) {
    .grid--3,
    .grid--4 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .grid--3,
    .grid--4 {
      grid-template-columns: 1fr;
    }

    .section {
      padding: 3.5rem 0;
    }
  }

  /* ── Story card (placeholder for Task 5 collection wiring) ── */
  .story-card {
    display: flex;
    flex-direction: column;
  }

  .story-card-body {
    padding-top: 1.5rem;
  }

  .story-card-eyebrow {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 0.75rem;
  }

  .story-card-title {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 22px;
    line-height: 1.25;
    margin: 0 0 0.875rem;
  }

  .story-card-title a {
    color: var(--primary);
    text-decoration: none;
    background-image: linear-gradient(var(--accent), var(--accent));
    background-size: 0 1px;
    background-position: 0 100%;
    background-repeat: no-repeat;
    transition: background-size 0.25s ease;
  }

  .story-card-title a:hover {
    background-size: 100% 1px;
  }

  .story-card-excerpt {
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 0;
  }

  /* ── Callout link override (dark variant) ── */
  .callout-link {
    color: var(--accent-light);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 2px;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .callout-link:hover {
    color: #ffffff;
  }
</style>
