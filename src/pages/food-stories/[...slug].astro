---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ImagePlaceholder from '../../components/ui/ImagePlaceholder.astro';
import CTABanner from '../../components/ui/CTABanner.astro';
import BlogPostingSchema from '../../components/schema/BlogPostingSchema.astro';

export async function getStaticPaths() {
  const stories = (await getCollection('stories', ({ data }) => !data.draft))
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

  return stories.map((story, idx) => ({
    params: { slug: story.slug },
    props: {
      story,
      newer: idx > 0 ? stories[idx - 1] : null,
      older: idx < stories.length - 1 ? stories[idx + 1] : null,
    },
  }));
}

interface Props {
  story: CollectionEntry<'stories'>;
  newer: CollectionEntry<'stories'> | null;
  older: CollectionEntry<'stories'> | null;
}

const { story, newer, older } = Astro.props;
const { Content } = await story.render();

const dateFormatter = new Intl.DateTimeFormat('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout
  title={`${story.data.title} | Food Stories | Kingsway International`}
  description={story.data.excerpt}
  ogType="article"
>
  <BlogPostingSchema
    slot="head"
    headline={story.data.title}
    description={story.data.excerpt}
    datePublished={story.data.date}
    slug={story.slug}
    category={story.data.category}
  />

  <!-- Hero -->
  <section class="story-hero" aria-labelledby="story-title">
    <div class="story-hero-inner">
      <p class="story-hero-eyebrow">
        <a href="/food-stories">Food Stories</a>
        <span aria-hidden="true">&rarr;</span>
        <span>{story.data.category}</span>
      </p>

      <h1 id="story-title" class="story-hero-title">{story.data.title}</h1>

      <p class="story-hero-meta">
        <span class="story-hero-category">{story.data.category}</span>
        <span aria-hidden="true">&middot;</span>
        <span>{story.data.readTime}</span>
        <span aria-hidden="true">&middot;</span>
        <time datetime={story.data.date.toISOString()}>
          {dateFormatter.format(story.data.date)}
        </time>
      </p>

      <div class="story-hero-image">
        <ImagePlaceholder label={story.data.title} aspect="16/9" />
      </div>
    </div>
  </section>

  <!-- Body -->
  <section class="story-body" aria-label="Story body">
    <div class="story-body-inner prose prose-lg prose-neutral">
      <Content />
    </div>
  </section>

  <!-- More stories -->
  {(newer || older) && (
    <section class="more-stories" aria-labelledby="more-heading">
      <div class="more-stories-inner">
        <h2 id="more-heading" class="more-stories-heading">More stories</h2>
        <div class="more-stories-grid">
          {older && (
            <a href={`/food-stories/${older.slug}`} class="more-story-card">
              <p class="more-story-direction">&larr; Older</p>
              <p class="more-story-category">{older.data.category}</p>
              <p class="more-story-title">{older.data.title}</p>
            </a>
          )}
          {newer && (
            <a href={`/food-stories/${newer.slug}`} class="more-story-card more-story-card--right">
              <p class="more-story-direction">Newer &rarr;</p>
              <p class="more-story-category">{newer.data.category}</p>
              <p class="more-story-title">{newer.data.title}</p>
            </a>
          )}
        </div>
      </div>
    </section>
  )}

  <CTABanner
    heading="Start a trade conversation"
    caption="We answer every enquiry within one business day."
    buttonLabel="Send an enquiry"
    buttonHref="/contact"
  />
</BaseLayout>

<style>
  /* ── Hero ── */
  .story-hero {
    background-color: #ffffff;
    padding: 4rem 0 3rem;
    border-bottom: 1px solid var(--rule);
  }

  .story-hero-inner {
    max-width: 880px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .story-hero-eyebrow {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 1.75rem;
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .story-hero-eyebrow a {
    color: var(--accent);
    text-decoration: none;
  }

  .story-hero-eyebrow a:hover {
    color: var(--primary);
  }

  .story-hero-title {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: clamp(34px, 5vw, 48px);
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: var(--primary);
    margin: 0 0 1.25rem;
  }

  .story-hero-meta {
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--grey);
    margin: 0 0 2.5rem;
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .story-hero-category {
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent);
    font-size: 11px;
  }

  .story-hero-image {
    margin-top: 1rem;
  }

  /* ── Body — manual prose styles (since global Tailwind base is off) ── */
  .story-body {
    background-color: #ffffff;
    padding: 3.5rem 0 4.5rem;
  }

  .story-body-inner {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 2rem;
    font-family: var(--font-sans);
    font-size: 18px;
    line-height: 1.75;
    color: var(--ink);
  }

  .story-body-inner :global(p) {
    margin: 0 0 1.5rem;
  }

  .story-body-inner :global(p:last-child) {
    margin-bottom: 0;
  }

  .story-body-inner :global(h2) {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 28px;
    line-height: 1.25;
    color: var(--primary);
    margin: 3rem 0 1.25rem;
  }

  .story-body-inner :global(h3) {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 22px;
    line-height: 1.3;
    color: var(--primary);
    margin: 2.5rem 0 1rem;
  }

  .story-body-inner :global(ul),
  .story-body-inner :global(ol) {
    margin: 0 0 1.5rem;
    padding-left: 1.5rem;
  }

  .story-body-inner :global(li) {
    margin-bottom: 0.5rem;
  }

  .story-body-inner :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding: 0.5rem 0 0.5rem 1.25rem;
    margin: 2rem 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 19px;
    line-height: 1.55;
    color: var(--ink-soft);
  }

  .story-body-inner :global(blockquote p) {
    margin: 0;
  }

  .story-body-inner :global(a) {
    color: var(--primary);
    border-bottom: 1px solid var(--accent);
    padding-bottom: 1px;
  }

  /* ── More stories ── */
  .more-stories {
    background-color: var(--light-tint);
    padding: 4rem 0;
    border-top: 1px solid var(--rule);
  }

  .more-stories-inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .more-stories-heading {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 2rem;
  }

  .more-stories-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .more-story-card {
    background: #ffffff;
    padding: 1.75rem;
    text-decoration: none;
    color: inherit;
    border-left: 3px solid var(--accent);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .more-story-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(8, 44, 34, 0.06);
  }

  .more-story-card--right {
    border-left: none;
    border-right: 3px solid var(--accent);
    text-align: right;
  }

  .more-story-direction {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 0.875rem;
  }

  .more-story-category {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--grey);
    margin: 0 0 0.5rem;
  }

  .more-story-title {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 19px;
    line-height: 1.3;
    color: var(--primary);
    margin: 0;
  }

  @media (max-width: 720px) {
    .more-stories-grid {
      grid-template-columns: 1fr;
    }

    .more-story-card--right {
      border-right: none;
      border-left: 3px solid var(--accent);
      text-align: left;
    }
  }
</style>
