---
interface Props {
  label: string;
  aspect?: string;
  class?: string;
}

const { label, aspect = '4/3', class: className = '' } = Astro.props;
---

<div
  class={`image-placeholder ${className}`.trim()}
  style={`aspect-ratio: ${aspect};`}
  role="img"
  aria-label={`Placeholder image: ${label}`}
>
  <span class="image-placeholder-label">{label}</span>
</div>

<style>
  .image-placeholder {
    position: relative;
    width: 100%;
    background-color: var(--light-tint);
    background-image: repeating-linear-gradient(
      45deg,
      var(--light) 0,
      var(--light) 14px,
      var(--light-tint) 14px,
      var(--light-tint) 28px
    );
    border: 1px solid var(--rule);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .image-placeholder::before {
    content: '';
    position: absolute;
    inset: 12px;
    border: 1px dashed var(--grey);
    opacity: 0.45;
    pointer-events: none;
  }

  .image-placeholder-label {
    position: relative;
    display: inline-block;
    padding: 0.5rem 1rem;
    background-color: rgba(255, 255, 255, 0.85);
    color: var(--grey);
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    border-radius: 2px;
    text-align: center;
    max-width: 80%;
    line-height: 1.4;
  }
</style>
