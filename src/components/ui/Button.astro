---
import type { HTMLAttributes } from 'astro/types';

type Variant = 'primary' | 'accent' | 'outline' | 'ghost';
type Size = 'sm' | 'md';

interface Props extends Omit<HTMLAttributes<'a'>, 'size'>, Omit<HTMLAttributes<'button'>, 'size'> {
  variant?: Variant;
  size?: Size;
  href?: string;
  withArrow?: boolean;
  type?: 'button' | 'submit' | 'reset';
}

const {
  variant = 'accent',
  size = 'md',
  href,
  withArrow = false,
  type = 'button',
  class: className = '',
  ...rest
} = Astro.props;

const variantClasses: Record<Variant, string> = {
  primary: 'bg-primary text-white hover:bg-primary-dark',
  accent:  'bg-accent text-white hover:bg-[#B37830]',
  outline: 'border border-white/40 text-white hover:bg-white/10',
  ghost:   'text-primary underline-offset-4 hover:underline',
};

const sizeClasses: Record<Size, string> = {
  sm: 'px-5 py-2.5 text-sm',
  md: 'px-7 py-3.5 text-sm',
};

const baseClasses =
  'inline-flex items-center justify-center gap-2 rounded-sm font-semibold tracking-wide transition-colors duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2';

const classes = `${baseClasses} ${variantClasses[variant]} ${sizeClasses[size]} ${className}`.trim();
---

{href ? (
  <a href={href} class={classes} {...rest}>
    <slot />
    {withArrow && <span aria-hidden="true">&rarr;</span>}
  </a>
) : (
  <button type={type} class={classes} {...rest}>
    <slot />
    {withArrow && <span aria-hidden="true">&rarr;</span>}
  </button>
)}
