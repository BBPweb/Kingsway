---
export interface Props {
  as?: 'p' | 'span' | 'div';
  class?: string;
}

const { as: Tag = 'p', class: className = '' } = Astro.props;
---

<Tag class={`eyebrow ${className}`.trim()}>
  <slot />
</Tag>

<style>
  .eyebrow {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 1.5rem;
    line-height: 1.2;
  }
</style>
