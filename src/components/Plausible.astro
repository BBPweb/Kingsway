---
// Optional Plausible analytics. Renders nothing unless PUBLIC_PLAUSIBLE_DOMAIN
// is set in .env. See .env.example and README.md.
const domain = import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN;
---

{domain && (
  <script
    is:inline
    defer
    data-domain={domain}
    src="https://plausible.io/js/script.js"
  ></script>
)}
