---
import ImagePlaceholder from '../ui/ImagePlaceholder.astro';

interface Props {
  number: string;
  eyebrow: string;
  title: string;
  body: string;
  linkLabel: string;
  linkHref: string;
  imageLabel?: string;
}

const {
  number,
  eyebrow,
  title,
  body,
  linkLabel,
  linkHref,
  imageLabel,
} = Astro.props;
---

<article class="feature-card">
  <ImagePlaceholder label={imageLabel ?? title} aspect="4/3" />

  <div class="feature-card-body">
    <p class="feature-card-number">{number}</p>
    <p class="feature-card-eyebrow">{eyebrow}</p>
    <h3 class="feature-card-title">{title}</h3>
    <p class="feature-card-text">{body}</p>
    <a href={linkHref} class="feature-card-link">
      <span>{linkLabel}</span>
      <span aria-hidden="true">&rarr;</span>
    </a>
  </div>
</article>

<style>
  .feature-card {
    display: flex;
    flex-direction: column;
    background: transparent;
  }

  .feature-card-body {
    padding-top: 1.5rem;
  }

  .feature-card-number {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1rem;
    color: var(--accent);
    margin: 0 0 0.5rem;
    letter-spacing: 0.05em;
  }

  .feature-card-eyebrow {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin: 0 0 0.75rem;
  }

  .feature-card-title {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 22px;
    line-height: 1.25;
    color: var(--primary);
    margin: 0 0 0.875rem;
  }

  .feature-card-text {
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.65;
    color: var(--ink-soft);
    margin: 0 0 1.25rem;
  }

  .feature-card-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 600;
    color: var(--primary);
    text-decoration: none;
    padding-bottom: 2px;
    border-bottom: 1px solid var(--accent);
    transition: gap 0.2s ease;
  }

  .feature-card-link:hover {
    gap: 0.7rem;
  }
</style>
