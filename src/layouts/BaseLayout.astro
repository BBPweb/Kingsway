---
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Plausible from '../components/Plausible.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
}

const {
  title,
  description,
  ogImage = '/og-default.svg',
  ogType = 'website',
} = Astro.props;

// If title starts with 'Kingsway', use as-is; otherwise append brand suffix
const pageTitle = title.startsWith('Kingsway')
  ? title
  : `${title} | Kingsway International`;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site).toString();
const isSvgOg = ogImage.endsWith('.svg');
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary SEO -->
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    {isSvgOg && <meta property="og:image:type" content="image/svg+xml" />}
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Kingsway International — UK Trading & Distribution" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="Kingsway International" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content="Kingsway International — UK Trading & Distribution" />

    <!-- Optional analytics (no-op unless PUBLIC_PLAUSIBLE_DOMAIN is set) -->
    <Plausible />

    <slot name="head" />
  </head>
  <body>
    <!-- Skip to main content — visible on keyboard focus -->
    <a href="#main" class="skip-link">Skip to content</a>

    <SiteHeader />

    <main id="main">
      <slot />
    </main>

    <SiteFooter />
  </body>
</html>
