# Formspree endpoints — create a project at formspree.io and paste the IDs here.
# Both env vars MUST start with PUBLIC_ so Astro exposes them to client-side code.
PUBLIC_FORMSPREE_CONTACT=https://formspree.io/f/xxxxxxxx
PUBLIC_FORMSPREE_NEWSLETTER=https://formspree.io/f/xxxxxxxx

# Optional — set to enable Plausible analytics (added in Task 7).
# PUBLIC_PLAUSIBLE_DOMAIN=kingswayinternational.co.uk
